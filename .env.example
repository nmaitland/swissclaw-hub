# Hub Environment Variables
# Copy this file to .env and fill in your values

# Server Configuration
NODE_ENV=development
PORT=3001

# Client URL (for CORS)
CLIENT_URL=http://localhost:3000

# Database (for local development)
# For Render, this is automatically set from the database connection
DATABASE_URL=postgresql://user:password@localhost:5432/hub
DB_SSL=false
# Set to false for providers that use self-signed certs (e.g. some managed Postgres defaults)
# DB_SSL_REJECT_UNAUTHORIZED=false
# Optional CA configuration when DB SSL is enabled:
# DB_SSL_CA=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----
# DB_SSL_CA_FILE=/path/to/ca.pem

# Production database (Render sets this automatically)
# DATABASE_URL=postgresql://...

# Authentication
# Username for login (default: admin)
AUTH_USERNAME=your_username
# Password for login (must be set in production; server fails to start if missing)
AUTH_PASSWORD=your_secure_password

# Hub URL (used by chat-bridge-webhook and other scripts)
HUB_URL=http://localhost:3001

# Optional: Bearer token for MCP server and automation tools
# Use a normal session token from /api/login or /auth/login
# HUB_AUTH_TOKEN=

# Session secret (for enhanced auth - if using server/routes/auth.ts)
# Generate with: openssl rand -base64 32
# SESSION_SECRET=your_session_secret_here

# Branding (all optional — defaults shown below)
# APP_NAME=My Hub
# APP_SHORT_NAME=Hub
# APP_DESCRIPTION=Web hub for chat, kanban, and status
# APP_ICON_EMOJI=🚀
# APP_THEME_COLOR=#FF4500
# APP_GITHUB_REPO=your-org/your-repo

# Google OAuth (optional - enables "Sign in with Google" on login page)
# Get from: https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
