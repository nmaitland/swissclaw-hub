# Swissclaw Hub Environment Variables
# Copy this file to .env and fill in your values

# Server Configuration
NODE_ENV=development
PORT=3001

# Client URL (for CORS)
CLIENT_URL=http://localhost:3000

# Database (for local development)
# For Render, this is automatically set from the database connection
DATABASE_URL=postgresql://user:password@localhost:5432/swissclaw_hub
DB_SSL=false
# Set to false for providers that use self-signed certs (e.g. some managed Postgres defaults)
# DB_SSL_REJECT_UNAUTHORIZED=false
# Optional CA configuration when DB SSL is enabled:
# DB_SSL_CA=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----
# DB_SSL_CA_FILE=/path/to/ca.pem

# Production database (Render sets this automatically)
# DATABASE_URL=postgresql://...

# Authentication
# Username for login (default: admin)
AUTH_USERNAME=admin
# Password for login (must be set in production; server fails to start if missing)
AUTH_PASSWORD=your_secure_password_here

# Hub URL (used by chat-bridge-webhook and other scripts)
SWISSCLAW_HUB_URL=http://localhost:3001

# Optional: Bearer token for MCP server and automation tools
# Use a normal session token from /api/login or /auth/login
# SWISSCLAW_AUTH_TOKEN=

# Session secret (for enhanced auth - if using server/routes/auth.ts)
# Generate with: openssl rand -base64 32
# SESSION_SECRET=your_session_secret_here
